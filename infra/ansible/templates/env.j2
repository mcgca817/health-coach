# Environment configuration
ENV={{ env_name }}
PUSH_WORKOUTS={{ push_workouts }}

# API Keys
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_ALERTS_TOKEN={{ telegram_alerts_token }}
INTERVALS_API_KEY={{ intervals_api_key }}
INTERVALS_ATHLETE_ID={{ intervals_athlete_id }}
CLAUDE_API_KEY={{ claude_api_key }}

# Telegram Chat IDs
TELEGRAM_MAIN_CHAT_ID={{ telegram_main_chat_id }}
TELEGRAM_ALERTS_CHAT_ID={{ telegram_alerts_chat_id }}

# Database (Internal Docker Network)
POSTGRES_HOST=healthcoach-postgres
POSTGRES_PORT=5432
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# SparkyFitness Database (Internal Docker Network)
SPARKY_HOST=sparkyfitness-db
SPARKY_PORT=5432
SPARKY_DB=sparkydb
SPARKY_USER={{ sparky_fitness_db_user }}
SPARKY_PASSWORD={{ sparky_fitness_db_password }}
SPARKY_USER_ID={{ sparky_user_id }}

# Google Drive
GDRIVE_REMOTE_PATH="{{ gdrive_remote_path }}"

# Google Sheets Sync
GOOGLE_SHEET_IDS="{{ google_sheet_ids }}"

# --- SPARKY FITNESS APP CONFIG ---
SPARKY_FITNESS_DB_NAME=sparkydb
SPARKY_FITNESS_DB_USER={{ sparky_fitness_db_user }}
SPARKY_FITNESS_DB_PASSWORD={{ sparky_fitness_db_password }}
SPARKY_FITNESS_APP_DB_USER={{ sparky_fitness_app_db_user }}
SPARKY_FITNESS_APP_DB_PASSWORD={{ sparky_fitness_app_db_password }}
SPARKY_FITNESS_API_ENCRYPTION_KEY={{ sparky_fitness_api_encryption_key }}
SPARKY_JWT_SECRET={{ sparky_jwt_secret }}
SPARKY_FITNESS_FRONTEND_URL={{ sparky_fitness_frontend_url }}
BETTER_AUTH_URL={{ sparky_fitness_frontend_url }}
BETTER_AUTH_ALLOWED_ORIGINS={{ sparky_fitness_frontend_url }}
SPARKY_FITNESS_ADMIN_EMAIL={{ sparky_fitness_admin_email }}
SPARKY_FITNESS_EMAIL_HOST={{ sparky_fitness_email_host }}
SPARKY_FITNESS_EMAIL_PORT={{ sparky_fitness_email_port }}
SPARKY_FITNESS_EMAIL_SECURE={{ sparky_fitness_email_secure }}
SPARKY_FITNESS_EMAIL_USER={{ sparky_fitness_email_user }}
SPARKY_FITNESS_EMAIL_PASS={{ sparky_fitness_email_pass }}
SPARKY_FITNESS_EMAIL_FROM={{ sparky_fitness_email_from }}
