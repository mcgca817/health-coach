# Environment configuration
ENV={{ env_name }}
PUSH_WORKOUTS={{ push_workouts }}

# API Keys
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_ALERTS_TOKEN={{ telegram_alerts_token }}
INTERVALS_API_KEY={{ intervals_api_key }}
INTERVALS_ATHLETE_ID={{ intervals_athlete_id }}
CLAUDE_API_KEY={{ claude_api_key }}

# Telegram Chat IDs
TELEGRAM_MAIN_CHAT_ID={{ telegram_main_chat_id }}
TELEGRAM_ALERTS_CHAT_ID={{ telegram_alerts_chat_id }}

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER={{ postgres_user }}
POSTGRES_PASSWORD={{ postgres_password }}
POSTGRES_DB={{ postgres_db }}

# SparkyFitness Database
SPARKY_HOST={{ sparky_host }}
SPARKY_PORT={{ sparky_port }}
SPARKY_DB={{ sparky_db }}
SPARKY_USER={{ sparky_user }}
SPARKY_PASSWORD={{ sparky_password }}
SPARKY_USER_ID={{ sparky_user_id }}

# Google Drive
GDRIVE_REMOTE_PATH="{{ gdrive_remote_path }}"
