apiVersion: 1

datasources:
  - name: HealthCoachDB
    type: postgres
    url: healthcoach-postgres:5432
    database: {{ postgres_db }}
    user: {{ postgres_user }}
    secureJsonData:
      password: {{ postgres_password }}
    jsonData:
      sslmode: 'disable' # Standard for internal docker networking
      postgresVersion: 16
      timescaledb: false
