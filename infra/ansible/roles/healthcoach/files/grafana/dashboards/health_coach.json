          "rawSql": "SELECT\n  time,\n  weight_kg_7d_avg AS \"Weight (7d Avg)\"\nFROM (\n  SELECT\n    date AS \"time\",\n    AVG(weight_kg) OVER(ORDER BY date ROWS BETWEEN 6 PRECEDING AND CURRENT ROW) AS weight_kg_7d_avg\n  FROM daily_biometrics\n) sub\nWHERE\n  $__timeFilter(time)\nORDER BY 1",
